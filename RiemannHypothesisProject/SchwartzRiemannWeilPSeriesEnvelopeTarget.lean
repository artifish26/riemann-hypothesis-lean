import RiemannHypothesisProject.SchwartzRiemannWeilAnalyticInputs

/-!
# P-series envelope targets for the Riemann-Weil route

`SchwartzRiemannWeilProfiledShellFormulaResidualInputData` is the preferred
final input package. This file names more analytic-facing special cases:
eventual p-series bounds for the extension envelope at zeta-zero arguments,
their cutoff-zero specialization, matching zero counting, formula identity, and
formula-side residual positivity. Lean assembles these into the final endpoint.

This keeps the next mathematical work unit explicit without adding axioms or
assuming any analytic theorem.
-/

namespace RiemannHypothesisProject

open Filter
open scoped Topology

/--
Zero-side data for the cutoff-zero p-series envelope route.

This package isolates the analytic estimates that produce the zero side:
* a complex extension envelope;
* a direct p-series envelope bound at every zeta-zero argument;
* first-entry zero counting with cutoff zero;
* the p-series decay margin beating zero-count growth by more than one.
-/
structure SchwartzRiemannWeilPSeriesEnvelopeZeroData where
  exhaustion : ComplexCompactExhaustion
  system : SchwartzRiemannWeilExtensionSystem
  growthBound : SchwartzRiemannWeilExtensionGrowthBound system
  zeroConstant : SchwartzLineTestFunction -> Real
  decayExponent : SchwartzLineTestFunction -> Real
  zeroConstant_nonneg :
    forall f : SchwartzLineTestFunction, 0 <= zeroConstant f
  pseriesBound_nonneg :
    forall (f : SchwartzLineTestFunction) (n : Nat),
      0 <= zeroConstant f *
        (1 / |(n : Real) + 1| ^ decayExponent f)
  envelope_zeroArgument_le_pseries :
    forall (f : SchwartzLineTestFunction) (rho : ZetaZeroSubtype),
      growthBound.envelope f (riemannWeilZeroArgument (rho : Complex)) <=
        zeroConstant f *
          (1 /
            |(exhaustion.zetaZeroFirstEntryIndex rho : Real) + 1| ^
              decayExponent f)
  counting : SchwartzRiemannWeilPolynomialZeroCountingEstimate exhaustion
  counting_cutoff_eq_zero : counting.cutoff = 0
  growth_add_one_lt_decay :
    forall f : SchwartzLineTestFunction,
      counting.growth + 1 < decayExponent f

namespace SchwartzRiemannWeilPSeriesEnvelopeZeroData

/-- The shell-decay data assembled from p-series envelope zero data. -/
noncomputable def shellDecay
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData) :
    SchwartzRiemannWeilExtensionShellDecayEstimate
      zeroData.exhaustion zeroData.system :=
  SchwartzRiemannWeilProfiledShellFormulaResidualInputData.shellDecayOfGlobalPSeriesEnvelopeBound
    zeroData.growthBound zeroData.zeroConstant zeroData.decayExponent
    zeroData.zeroConstant_nonneg zeroData.pseriesBound_nonneg
    zeroData.envelope_zeroArgument_le_pseries

/-- The profiled separated tail estimate assembled from p-series zero data. -/
noncomputable def profiledTailEstimate
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData) :
    SchwartzRiemannWeilProfiledSeparatedTailEstimate
      zeroData.exhaustion zeroData.system :=
  SchwartzRiemannWeilProfiledShellFormulaResidualInputData.profiledTailEstimateOfGlobalPSeriesEnvelopeAndCounting
    zeroData.growthBound zeroData.zeroConstant zeroData.decayExponent
    zeroData.zeroConstant_nonneg zeroData.pseriesBound_nonneg
    zeroData.envelope_zeroArgument_le_pseries zeroData.counting
    zeroData.counting_cutoff_eq_zero zeroData.growth_add_one_lt_decay

/-- The zero side generated by the p-series envelope estimate. -/
noncomputable def zeroSide
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData) :
    SchwartzRiemannWeilZeroSide :=
  zeroData.profiledTailEstimate.toZeroSide

/-- The generated zero side uses the candidate extension-system weight. -/
theorem zeroSide_weight
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData)
    (f : SchwartzLineTestFunction)
    (rho : ZetaZeroSubtype) :
    zeroData.zeroSide.weight f rho = zeroData.system.weight f rho :=
  zeroData.profiledTailEstimate.toZeroSide_weight f rho

/-- Compact-exhaustion sums converge for the generated zero side. -/
theorem tendsto_windowZeroSide
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData)
    (windowExhaustion : ComplexCompactExhaustion)
    (f : SchwartzLineTestFunction) :
    Tendsto
      (fun n : Nat => zeroData.zeroSide.windowZeroSide windowExhaustion n f)
      atTop (nhds (zeroData.zeroSide.zeroSide f)) :=
  zeroData.profiledTailEstimate.tendsto_windowZeroSide windowExhaustion f

end SchwartzRiemannWeilPSeriesEnvelopeZeroData

/-- Formula identity data relative to p-series envelope zero data. -/
structure SchwartzRiemannWeilPSeriesEnvelopeFormulaData
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData) where
  formulaData :
    SchwartzRiemannWeilFormulaIdentityData zeroData.zeroSide

namespace SchwartzRiemannWeilPSeriesEnvelopeFormulaData

/-- Build cutoff-zero formula data directly from raw formula sides. -/
noncomputable def ofRawSides
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    (primeSide poleSide gammaSide : SchwartzLineTestFunction -> Real)
    (explicitFormula :
      forall f : SchwartzLineTestFunction,
        zeroData.zeroSide.zeroSide f =
          primeSide f + poleSide f + gammaSide f) :
    SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData where
  formulaData :=
    SchwartzRiemannWeilFormulaIdentityData.ofRawSides
      primeSide poleSide gammaSide explicitFormula

/-- Compact-exhaustion sums converge to the formula-side residual expression. -/
theorem tendsto_windowZeroSide_formulaResidualSide
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    (formulaData :
      SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData)
    (windowExhaustion : ComplexCompactExhaustion)
    (f : SchwartzLineTestFunction) :
    Tendsto
      (fun n : Nat => zeroData.zeroSide.windowZeroSide windowExhaustion n f)
      atTop (nhds (formulaData.formulaData.sideData.residualSide f)) := by
  rw [← formulaData.formulaData.explicitFormula f]
  exact zeroData.tendsto_windowZeroSide windowExhaustion f

end SchwartzRiemannWeilPSeriesEnvelopeFormulaData

/-- Formula-side residual positivity relative to p-series envelope formula data. -/
structure SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    (formulaData : SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData) where
  formulaResidualData :
    SchwartzRiemannWeilFormulaResidualPositivityData formulaData.formulaData

namespace SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData

/-- Build cutoff-zero residual positivity directly from raw residual-side data. -/
noncomputable def ofRawResidualPositivity
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    {formulaData : SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData}
    (residual_nonneg :
      forall f : SchwartzLineTestFunction,
        0 <= formulaData.formulaData.sideData.residualSide f)
    (residual_positivity_implies_RHOn_univ :
      (forall f : SchwartzLineTestFunction,
        0 <= formulaData.formulaData.sideData.residualSide f) ->
        RHOn (fun _ : Complex => True)) :
    SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData formulaData where
  formulaResidualData :=
    SchwartzRiemannWeilFormulaResidualPositivityData.ofRawResidualPositivity
      residual_nonneg residual_positivity_implies_RHOn_univ

/-- The packaged formula residual side is nonnegative. -/
theorem formulaResidual_nonneg
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    {formulaData : SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData}
    (positivityData :
      SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData formulaData)
    (f : SchwartzLineTestFunction) :
    0 <= formulaData.formulaData.sideData.residualSide f :=
  positivityData.formulaResidualData.residual_nonneg f

/-- Formula-side residual positivity proves universal local RH. -/
theorem formulaResidual_positivity_implies_RHOn_univ
    {zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData}
    {formulaData : SchwartzRiemannWeilPSeriesEnvelopeFormulaData zeroData}
    (positivityData :
      SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData formulaData) :
    (forall f : SchwartzLineTestFunction,
      0 <= formulaData.formulaData.sideData.residualSide f) ->
      RHOn (fun _ : Complex => True) :=
  positivityData.formulaResidualData.residual_positivity_implies_RHOn_univ

end SchwartzRiemannWeilPSeriesEnvelopeResidualPositivityData

/--
Zero-side data for the eventual p-series envelope route.

This is the realistic version of the p-series envelope target: finite-prefix
behavior is controlled by `prefixBound`, while the p-series tail begins after
`cutoff`.
-/
structure SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData where
  exhaustion : ComplexCompactExhaustion
  system : SchwartzRiemannWeilExtensionSystem
  growthBound : SchwartzRiemannWeilExtensionGrowthBound system
  cutoff : Nat
  prefixBound : SchwartzLineTestFunction -> Nat -> Real
  zeroConstant : SchwartzLineTestFunction -> Real
  decayExponent : SchwartzLineTestFunction -> Real
  zeroConstant_nonneg :
    forall f : SchwartzLineTestFunction, 0 <= zeroConstant f
  prefixBound_nonneg :
    forall (f : SchwartzLineTestFunction) (n : Nat), 0 <= prefixBound f n
  pseriesBound_nonneg :
    forall (f : SchwartzLineTestFunction) (n : Nat),
      0 <= zeroConstant f *
        (1 / |(n : Real) + 1| ^ decayExponent f)
  envelope_zeroArgument_le_eventualPSeries :
    forall (f : SchwartzLineTestFunction) (rho : ZetaZeroSubtype),
      growthBound.envelope f (riemannWeilZeroArgument (rho : Complex)) <=
        SchwartzRiemannWeilExtensionShellDecayEstimate.eventualPSeriesShellBound
          cutoff prefixBound zeroConstant decayExponent f
          (exhaustion.zetaZeroFirstEntryIndex rho)
  counting : SchwartzRiemannWeilPolynomialZeroCountingEstimate exhaustion
  counting_cutoff_eq : counting.cutoff = cutoff
  growth_add_one_lt_decay :
    forall f : SchwartzLineTestFunction,
      counting.growth + 1 < decayExponent f

namespace SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData

/-- Cutoff-zero p-series zero data is a special case of eventual p-series zero data. -/
noncomputable def ofCutoffZero
    (zeroData : SchwartzRiemannWeilPSeriesEnvelopeZeroData) :
    SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData where
  exhaustion := zeroData.exhaustion
  system := zeroData.system
  growthBound := zeroData.growthBound
  cutoff := 0
  prefixBound := fun f n =>
    zeroData.zeroConstant f *
      (1 / |(n : Real) + 1| ^ zeroData.decayExponent f)
  zeroConstant := zeroData.zeroConstant
  decayExponent := zeroData.decayExponent
  zeroConstant_nonneg := zeroData.zeroConstant_nonneg
  prefixBound_nonneg := zeroData.pseriesBound_nonneg
  pseriesBound_nonneg := zeroData.pseriesBound_nonneg
  envelope_zeroArgument_le_eventualPSeries := fun f rho => by
    simpa [SchwartzRiemannWeilExtensionShellDecayEstimate.eventualPSeriesShellBound]
      using zeroData.envelope_zeroArgument_le_pseries f rho
  counting := zeroData.counting
  counting_cutoff_eq := zeroData.counting_cutoff_eq_zero
  growth_add_one_lt_decay := zeroData.growth_add_one_lt_decay

/--
Build eventual p-series envelope zero data from an exact polynomial
shell-cardinality bound and an eventual p-series envelope bound.
-/
noncomputable def ofExactShellCardAndEventualPSeriesEnvelopeBound
    {exhaustion : ComplexCompactExhaustion}
    {system : SchwartzRiemannWeilExtensionSystem}
    (growthBound : SchwartzRiemannWeilExtensionGrowthBound system)
    (cutoff : Nat)
    (prefixBound : SchwartzLineTestFunction -> Nat -> Real)
    (zeroConstant : SchwartzLineTestFunction -> Real)
    (decayExponent : SchwartzLineTestFunction -> Real)
    (shellCardConstant growth : Real)
    (zeroConstant_nonneg :
      forall f : SchwartzLineTestFunction, 0 <= zeroConstant f)
    (prefixBound_nonneg :
      forall (f : SchwartzLineTestFunction) (n : Nat), 0 <= prefixBound f n)
    (pseriesBound_nonneg :
      forall (f : SchwartzLineTestFunction) (n : Nat),
        0 <= zeroConstant f *
          (1 / |(n : Real) + 1| ^ decayExponent f))
    (shellCardConstant_nonneg : 0 <= shellCardConstant)
    (tail_shellCard_le :
      forall n : Nat,
        ((exhaustion.zetaZeroFirstEntryShell (n + cutoff)).card : Real) <=
          shellCardConstant * |(n : Real) + 1| ^ growth)
    (envelope_zeroArgument_le_eventualPSeries :
      forall (f : SchwartzLineTestFunction) (rho : ZetaZeroSubtype),
        growthBound.envelope f (riemannWeilZeroArgument (rho : Complex)) <=
          SchwartzRiemannWeilExtensionShellDecayEstimate.eventualPSeriesShellBound
            cutoff prefixBound zeroConstant decayExponent f
            (exhaustion.zetaZeroFirstEntryIndex rho))
    (growth_add_one_lt_decay :
      forall f : SchwartzLineTestFunction, growth + 1 < decayExponent f) :
    SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData where
  exhaustion := exhaustion
  system := system
  growthBound := growthBound
  cutoff := cutoff
  prefixBound := prefixBound
  zeroConstant := zeroConstant
  decayExponent := decayExponent
  zeroConstant_nonneg := zeroConstant_nonneg
  prefixBound_nonneg := prefixBound_nonneg
  pseriesBound_nonneg := pseriesBound_nonneg
  envelope_zeroArgument_le_eventualPSeries :=
    envelope_zeroArgument_le_eventualPSeries
  counting :=
    SchwartzRiemannWeilPolynomialZeroCountingEstimate.ofExactShellCardPolynomialBound
      exhaustion cutoff shellCardConstant growth shellCardConstant_nonneg
      tail_shellCard_le
  counting_cutoff_eq := rfl
  growth_add_one_lt_decay := growth_add_one_lt_decay

