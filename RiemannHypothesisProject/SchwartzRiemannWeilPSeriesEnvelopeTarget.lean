/-- The package's zero side is the packaged formula residual side. -/
theorem zeroSide_eq_formulaResidualSide
    (data : SchwartzRiemannWeilPSeriesEnvelopeFormulaResidualInputData)
    (f : SchwartzLineTestFunction) :
    data.toProfiledTailCertificateData.zeroSide.zeroSide f =
      data.formulaData.sideData.residualSide f :=
  (data.toProfiledShellFormulaResidualInputData).zeroSide_eq_formulaResidualSide f

/-- The package's quadratic form is the packaged formula residual side. -/
