/-- Formula identity data relative to eventual p-series envelope zero data. -/
structure SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaData
    (zeroData : SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData) where
  formulaData :
    SchwartzRiemannWeilFormulaIdentityData zeroData.zeroSide

namespace SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaData

/-- Build eventual formula data directly from raw formula sides. -/
noncomputable def ofRawSides
    {zeroData : SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData}
    (primeSide poleSide gammaSide : SchwartzLineTestFunction -> Real)
    (explicitFormula :
      forall f : SchwartzLineTestFunction,
        zeroData.zeroSide.zeroSide f =
          primeSide f + poleSide f + gammaSide f) :
    SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaData zeroData where
  formulaData :=
    SchwartzRiemannWeilFormulaIdentityData.ofRawSides
      primeSide poleSide gammaSide explicitFormula

/-- Compact-exhaustion sums converge to the formula-side residual expression. -/
theorem tendsto_windowZeroSide_formulaResidualSide
    {zeroData : SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData}
    (formulaData :
      SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaData zeroData)
    (windowExhaustion : ComplexCompactExhaustion)
    (f : SchwartzLineTestFunction) :
    Tendsto
