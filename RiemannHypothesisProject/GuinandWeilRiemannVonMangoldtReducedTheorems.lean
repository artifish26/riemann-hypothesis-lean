/-!
# Guinand-Weil/Riemann-von Mangoldt reduced conditional RH theorems

This module combines the source-normalized Guinand-Weil formula package with
the closed-ball Riemann-von-Mangoldt constant-decay p-series route. It does not
prove the analytic Guinand-Weil formula or positivity theorem; instead, it
turns those named inputs into the reduced theorem-facing RH endpoints without
requiring the caller to restate raw prime, pole, and gamma formula sides. It
also exposes published and fixed-error `N(T)` source wrappers for the basic
source-formula route by converting those counting sources through the named
Riemann-von-Mangoldt target.
-/

namespace RiemannHypothesisProject

section GuinandWeilRiemannVonMangoldtConstantDecay

variable (target :
  ComplexCompactExhaustion.ClosedBallZeroRiemannVonMangoldtCountingTarget)
variable {system : SchwartzRiemannWeilExtensionSystem}
variable (growthBound : SchwartzRiemannWeilExtensionGrowthBound system)
variable (prefixBound : SchwartzLineTestFunction -> Nat -> Real)
variable (zeroConstant : SchwartzLineTestFunction -> Real)
variable (decayExponent : Real)
variable (zeroConstant_nonneg :
  forall f : SchwartzLineTestFunction, 0 <= zeroConstant f)
variable (prefixBound_nonneg :
  forall (f : SchwartzLineTestFunction) (n : Nat), 0 <= prefixBound f n)
variable (envelope_zeroArgument_le_eventualConstantPSeries :
  forall (f : SchwartzLineTestFunction) (rho : ZetaZeroSubtype),
    growthBound.envelope f (riemannWeilZeroArgument (rho : Complex)) <=
      SchwartzRiemannWeilExtensionShellDecayEstimate.eventualConstantPSeriesShellBound
        target.cutoff prefixBound zeroConstant decayExponent f
        (ComplexCompactExhaustion.closedBallZero.zetaZeroFirstEntryIndex rho))
variable (growth_add_one_lt_decay : target.growth + 1 < decayExponent)
variable (sourcePackage : GuinandWeilSourceFormulaPackage)
variable (normalizationBridge :
  GuinandWeilNormalizationBridge sourcePackage.sourceData
    (target.toEventualPSeriesEnvelopeZeroDataConstantDecay
      growthBound prefixBound zeroConstant decayExponent zeroConstant_nonneg
      prefixBound_nonneg envelope_zeroArgument_le_eventualConstantPSeries
      growth_add_one_lt_decay).zeroSide)
variable (source_residual_nonneg :
  forall f : SchwartzLineTestFunction,
    0 <= sourcePackage.sourceData.sideData.sourceResidualSide f)
variable (source_residual_positivity_implies_RHOn_univ :
  (forall f : SchwartzLineTestFunction,
    0 <= sourcePackage.sourceData.sideData.sourceResidualSide f) ->
    RHOn (fun _ : Complex => True))

include target growthBound prefixBound zeroConstant decayExponent
  zeroConstant_nonneg prefixBound_nonneg
  envelope_zeroArgument_le_eventualConstantPSeries growth_add_one_lt_decay
  sourcePackage normalizationBridge source_residual_nonneg
  source_residual_positivity_implies_RHOn_univ

/--
The zero data generated by the closed-ball Riemann-von-Mangoldt target and the
constant-decay envelope estimate.
-/
noncomputable def RiemannVonMangoldtGuinandWeilZeroData :
    SchwartzRiemannWeilEventualPSeriesEnvelopeZeroData :=
  target.toEventualPSeriesEnvelopeZeroDataConstantDecay
    growthBound prefixBound zeroConstant decayExponent zeroConstant_nonneg
    prefixBound_nonneg envelope_zeroArgument_le_eventualConstantPSeries
    growth_add_one_lt_decay

/--
The project Guinand-Weil formula package normalized to the zero side generated
by the Riemann-von-Mangoldt/p-series route.
-/
noncomputable def RiemannVonMangoldtGuinandWeilProjectFormulaPackage :
    GuinandWeilProjectFormulaPackage
      (RiemannVonMangoldtGuinandWeilZeroData
        target growthBound prefixBound zeroConstant decayExponent
        zeroConstant_nonneg prefixBound_nonneg
        envelope_zeroArgument_le_eventualConstantPSeries
        growth_add_one_lt_decay).zeroSide where
  sourcePackage := sourcePackage
  normalizationBridge := normalizationBridge

/--
Assemble the closed-ball Riemann-von-Mangoldt count, constant-decay envelope,
and Guinand-Weil source formula package into the compact eventual p-series
formula-residual endpoint.
-/
noncomputable def
    eventualPSeriesInputDataOfRiemannVonMangoldtGuinandWeilConstantDecay :
    SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaResidualInputData := by
  let zeroData :=
    RiemannVonMangoldtGuinandWeilZeroData
      target growthBound prefixBound zeroConstant decayExponent
      zeroConstant_nonneg prefixBound_nonneg
      envelope_zeroArgument_le_eventualConstantPSeries
      growth_add_one_lt_decay
  let projectPackage : GuinandWeilProjectFormulaPackage zeroData.zeroSide :=
    { sourcePackage := sourcePackage
      normalizationBridge := normalizationBridge }
  exact
    SchwartzRiemannWeilEventualPSeriesEnvelopeFormulaResidualInputData.ofZeroDataAndRawFormulaResidual
        zeroData
        sourcePackage.sourceData.sideData.sourcePrimeSide
        sourcePackage.sourceData.sideData.sourcePoleSide
        sourcePackage.sourceData.sideData.sourceGammaSide
        (fun f => by
          simpa [GuinandWeilFormulaSideData.sourceResidualSide]
            using projectPackage.explicitFormula_sourceResidualSide f)
        (fun f => by
          simpa [GuinandWeilFormulaSideData.sourceResidualSide]
            using source_residual_nonneg f)
        (fun hres => source_residual_positivity_implies_RHOn_univ <| fun f => by
          have hf := hres f
          simpa [GuinandWeilFormulaSideData.sourceResidualSide] using hf)

/--
A closed-ball Riemann-von-Mangoldt counting target, constant-decay envelope, and
Guinand-Weil source formula package prove universal local RH.
-/
theorem RHOn_univ_of_RiemannVonMangoldt_GuinandWeil_constantDecay :
    RHOn (fun _ : Complex => True) :=
  (eventualPSeriesInputDataOfRiemannVonMangoldtGuinandWeilConstantDecay
    (target := target)
    (growthBound := growthBound)
    (prefixBound := prefixBound)
    (zeroConstant := zeroConstant)
    (decayExponent := decayExponent)
    (zeroConstant_nonneg := zeroConstant_nonneg)
    (prefixBound_nonneg := prefixBound_nonneg)
    (envelope_zeroArgument_le_eventualConstantPSeries :=
      envelope_zeroArgument_le_eventualConstantPSeries)
    (growth_add_one_lt_decay := growth_add_one_lt_decay)
    (sourcePackage := sourcePackage)
    (normalizationBridge := normalizationBridge)
    (source_residual_nonneg := source_residual_nonneg)
    (source_residual_positivity_implies_RHOn_univ :=
      source_residual_positivity_implies_RHOn_univ)).RHOn_univ

/--
A closed-ball Riemann-von-Mangoldt counting target, constant-decay envelope, and
Guinand-Weil source formula package prove the project RH statement.
-/
theorem RHStatement_of_RiemannVonMangoldt_GuinandWeil_constantDecay :
